# X87 Subtitle Service — environment variable configuration
# Copy this file to .env and fill in your values.
# The server loads this file automatically on startup.

# ─── subs.ro (priority 1) ────────────────────────────────────────────────────
# Your subs.ro API key (from https://www.subs.ro — account → API).
# Leave empty to skip this provider.
SUBSRO_API_KEY=your_subsro_api_key_here

# ─── OpenSubtitles VIP REST API (priority 2) ─────────────────────────────────
# Your consumer API key (from https://www.opensubtitles.com — profile → API)
OPENSUBTITLES_API_KEY=your_api_key_here

# Your OpenSubtitles account credentials
OPENSUBTITLES_USERNAME=your_username_here
OPENSUBTITLES_PASSWORD=your_password_here
