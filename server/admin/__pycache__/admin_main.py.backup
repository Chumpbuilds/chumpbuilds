X87 Player - Main Admin Application
Entry point and core application setup
Current Date and Time (UTC): 2025-11-20 09:06:06
Current User: covchump
Domain: https://x87player.xyz
"""

from flask import Flask, session, redirect, url_for
from flask_cors import CORS
import os
import sys

# Add current directory to path for imports
sys.path.append(os.path.dirname(os.path.abspath(__file__)))

# Import modules
from admin_database import init_database, migrate_database, DB_PATH
from admin_auth import auth_bp
from admin_dashboard import dashboard_bp
from admin_customers import customers_bp
from admin_users import users_bp
from admin_profile import profile_bp
from admin_api import api_bp

# Create Flask application
app = Flask(__name__)
app.secret_key = os.environ.get('SECRET_KEY', 'x87player_secret_key_CHANGE_IN_PRODUCTION_2025')

# Enable CORS for API endpoints
CORS(app, resources={
    r"/api/*": {
        "origins": ["https://x87player.xyz", "http://localhost:*"],
        "methods": ["GET", "POST", "PUT", "DELETE"],
        "allow_headers": ["Content-Type", "Authorization"]
    }
})

# Register blueprints
app.register_blueprint(auth_bp)
app.register_blueprint(dashboard_bp)
app.register_blueprint(customers_bp)
app.register_blueprint(users_bp)
app.register_blueprint(profile_bp)
app.register_blueprint(api_bp)

# Root route redirect
@app.route('/')
def index():
    if 'logged_in' in session and session['logged_in']:
        return redirect(url_for('dashboard.admin_dashboard'))
    return redirect(url_for('auth.login'))

if __name__ == '__main__':
    print("\n" + "="*70)
    print("🚀 X87 Player Business Admin Panel Starting...")
    print("="*70)
    
    # Initialize database
    if os.path.exists(DB_PATH):
        migrate_database()
    
    init_database()
    
    print("🎯 Flask application starting...")
    print("✅ Server ready for connections!")
    print()
    print("⚠️  IMPORTANT: Change default admin password after first login!")
    print()
    
    app.run(
        host='0.0.0.0',
        port=5000,
        debug=True
    )