# OpenSubtitles VIP REST API credentials
# Copy this file to .env and fill in your values.
# The server loads this file automatically on startup.

# Your consumer API key (from https://www.opensubtitles.com — profile → API)
OPENSUBTITLES_API_KEY=your_api_key_here

# Your OpenSubtitles account credentials
OPENSUBTITLES_USERNAME=your_username_here
OPENSUBTITLES_PASSWORD=your_password_here
